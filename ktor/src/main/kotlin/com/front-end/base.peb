<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{% block title %}Aetheria{% endblock %}</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Navbar -->
    {% include "navbar.peb" %}

    <!-- Main Content -->
    <main>
        {% block content %}
    
        {% endblock %}
    </main>

    <!-- Footer -->
    {% include "footer.peb" %}

</body>
</html>