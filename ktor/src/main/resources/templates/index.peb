</div>
</header>

    <main id="main-content">
        <section class="relative min-h-screen flex flex-col items-center justify-center pt-32 px-6 overflow-hidden">
            <div class="absolute inset-0 -z-10 bg-slate-200">
                <img src="https://images.unsplash.com/photo-1542296332-2e4473faf563?auto=format&fit=crop&w=1920&q=80" alt="Jet wing above clouds" class="w-full h-full object-cover opacity-30 grayscale">
            </div>

            <div class="text-center mb-12">
                <h1 class="text-6xl md:text-8xl serif font-light leading-tight mb-4">
                    The Art of <span class="italic text-[--sky-blue]">Arrival</span>
                </h1>
                <p class="text-gray-400 uppercase tracking-[0.4em] text-[10px] font-bold">Bespoke Private Flight Charters</p>
            </div>

            <div class="float-card w-full max-w-5xl rounded-[40px] overflow-hidden">
                <div class="flex border-b border-gray-100 px-8 py-4 gap-8">
                    <button class="text-[10px] uppercase tracking-widest font-extrabold text-[--sky-blue] border-b-2 border-[--sky-blue] pb-1">Round Trip</button>
                    <button class="text-[10px] uppercase tracking-widest font-extrabold text-gray-300 hover:text-black transition-all pb-1">One Way</button>
                    <button class="text-[10px] uppercase tracking-widest font-extrabold text-gray-300 hover:text-black transition-all pb-1">Multi-City</button>
                </div>

                <form action="/search" method="GET" class="p-8 md:p-10 grid grid-cols-1 md:grid-cols-4 gap-8 items-end">
                    <div class="relative group">
                        <label for="origin" class="text-[10px] uppercase font-extrabold text-[--sky-blue] mb-2 block tracking-widest">Origin</label>
                        <input type="text" id="origin" name="from" list="locations" placeholder="From where?" autocomplete="off" class="w-full bg-transparent border-b border-gray-200 pb-2 text-lg font-medium outline-none focus:border-[--sky-blue] transition-all placeholder:text-gray-300 custom-input" aria-required="true">
                    </div>

                    <div class="relative group">
                        <label for="destination" class="text-[10px] uppercase font-extrabold text-[--sky-blue] mb-2 block tracking-widest">Destination</label>
                        <input type="text" id="destination" name="to" list="locations" placeholder="To where?" autocomplete="off" class="w-full bg-transparent border-b border-gray-200 pb-2 text-lg font-medium outline-none focus:border-[--sky-blue] transition-all placeholder:text-gray-300 custom-input" aria-required="true">
                    </div>

                    <div>
                        <label for="date" class="text-[10px] uppercase font-extrabold text-[--sky-blue] mb-2 block tracking-widest">Departure</label>
                        <input type="date" id="date" name="date" class="w-full bg-transparent border-b border-gray-200 pb-2 text-lg font-medium outline-none text-gray-400 cursor-pointer focus:border-[--sky-blue] transition-colors">
                    </div>

                    <button type="submit" class="w-full bg-[--charcoal] text-white py-5 rounded-2xl font-extrabold uppercase tracking-widest text-[10px] hover:bg-[--sky-blue] transition-all duration-500 active:scale-95 shadow-lg">
                        Find Availability
                    </button>

                    <datalist id="locations">
                        <option value="Amsterdam (AMS) — Netherlands">
                        <option value="Aspen (ASE) — United States">
                        <option value="Dubai (DXB) — United Arab Emirates">
                        <option value="Hong Kong (HKG) — China">
                        <option value="London (LHR) — United Kingdom">
                        <option value="Maldives (MLE) — Maldives">
                        <option value="New York (JFK) — United States">
                        <option value="Paris (CDG) — France">
                        <option value="Singapore (SIN) — Singapore">
                        <option value="Tokyo (HND) — Japan">
                    </datalist>
                </form>
            </div>
        </section>

        <section class="max-w-6xl mx-auto px-6 mt-4 mb-10 relative z-20">
            <div class="bg-[--charcoal] rounded-[40px] p-10 md:p-14 shadow-2xl flex flex-col md:flex-row items-center justify-between overflow-hidden relative border border-gray-800">
                <div class="absolute top-0 right-10 w-64 h-64 bg-[--gold] rounded-full blur-[100px] glow-blob pointer-events-none"></div>
                <div class="absolute bottom-[-50px] left-10 w-48 h-48 bg-[--sky-blue] rounded-full blur-[80px] glow-blob pointer-events-none" style="animation-delay: -4s;"></div>

                <div class="relative z-10 text-white mb-8 md:mb-0 max-w-2xl">
                    <p class="text-[10px] uppercase tracking-[0.3em] text-[--gold-light] font-bold mb-4">Elevate Every Journey</p>
                    <h2 class="text-4xl md:text-5xl serif mb-4 leading-tight">Become an <span class="italic font-light">AetherianFly</span> Member</h2>
                    <p class="text-gray-400 text-sm md:text-base font-light leading-relaxed">Unlock priority boarding, complimentary upgrades, and exclusive global lounges.</p>
                </div>
                <div class="relative z-10">
                    <a href="/register" class="bg-[--gold-light] text-black px-10 py-5 rounded-full text-xs uppercase tracking-widest font-extrabold hover:bg-white transition-all transform hover:scale-105 active:scale-95">Join Now</a>
                </div>
            </div>
        </section>

        <section class="max-w-[1440px] mx-auto px-8 pt-4 pb-4">
            <div class="flex justify-between items-end mb-12 max-w-7xl mx-auto px-6">
                <div>
                    <span class="text-[10px] uppercase tracking-[0.3em] text-[--sky-blue] font-bold block mb-4">Curated Journeys</span>
                    <h2 class="text-4xl md:text-5xl serif leading-tight">Featured Destinations</h2>
                </div>
                <a href="#" class="border-b border-gray-300 pb-1 text-[10px] uppercase tracking-widest font-extrabold text-gray-500 hover:text-black transition-all">Explore All Routes</a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                <a href="#" class="dest-card zoom-img group relative aspect-square rounded-[32px] overflow-hidden shadow-lg border border-gray-100">
                    <img src="https://images.unsplash.com/photo-1525625293386-3f8f99389edd?auto=format&fit=crop&w=800&q=80" alt="Singapore" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
                    <div class="absolute bottom-8 left-8 text-white">
                        <p class="text-[9px] uppercase tracking-widest font-bold mb-2">Urban Oasis</p>
                        <h3 class="text-2xl serif">Singapore</h3>
                    </div>
                </a>
                <a href="#" class="dest-card zoom-img group relative aspect-square rounded-[32px] overflow-hidden shadow-lg border border-gray-100">
