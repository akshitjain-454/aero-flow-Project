                <div class="absolute bottom-[-50px] left-10 w-48 h-48 bg-[--sky-blue] rounded-full blur-[80px] glow-blob pointer-events-none" style="animation-delay: -4s;"></div>

                <div class="relative z-10 text-white mb-8 md:mb-0 max-w-2xl">
