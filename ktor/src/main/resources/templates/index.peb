{% extends "base.html" %}

{% block title %}Aetheria | Sky-High Elegance{% endblock %}

{% block extra_css %}
        body { 
            background-color: var(--pearl); 
            color: var(--charcoal);
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        .float-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 1);
            box-shadow: 0 40px 100px -20px rgba(0, 40, 100, 0.1);
        }

        .nav-link {
            position: relative;
            padding-bottom: 6px;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 3px; 
            background-color: var(--sky-blue);
            transition: width 0.3s ease-in-out;
            border-radius: 3px;
        }
        .nav-link:hover::after { width: 100%; }
        
        .focus-within-ring:focus-within {
            outline: 3px solid var(--sky-blue);
            outline-offset: 4px;
        }

        .zoom-img { background-color: #E2E8F0; }
        .zoom-img img { transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
        .zoom-img:hover img { transform: scale(1.08); }

        .custom-input {
            background-image: linear-gradient(var(--sky-blue), var(--sky-blue));
            background-size: 0% 2px;
            background-repeat: no-repeat;
            background-position: bottom left;
            transition: background-size 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        .custom-input:focus { background-size: 100% 2px; }
        input::-webkit-calendar-picker-indicator { display: none !important; }

        @keyframes ambientGlow {
            0% { transform: scale(1) translate(0, 0); opacity: 0.1; }
            50% { transform: scale(1.2) translate(20px, -20px); opacity: 0.2; }
            100% { transform: scale(1) translate(0, 0); opacity: 0.1; }
        }
        .glow-blob { animation: ambientGlow 8s infinite alternate ease-in-out; }

        .banner-fallback { background: linear-gradient(to right, #1A1A1A, #2D3748); }
{% endblock %}

{% block body_classes %}relative{% endblock %}

{% block content %}
    <a href="#main-content" class="absolute -top-[100px] left-4 bg-[--sky-blue] text-white px-6 py-3 text-xs font-bold uppercase tracking-widest z-[1000] focus:top-4 transition-all duration-300 rounded-b-xl shadow-2xl">
        Skip to main content
    </a>

    <header class="w-full px-8 py-6 flex justify-between items-center fixed top-0 z-50 bg-white/60 backdrop-blur-lg border-b border-gray-100">
        <div class="text-2xl font-bold tracking-tighter serif text-[--sky-blue] z-10" aria-label="Aetheria Home">
            AETHERIA
        </div>
        <nav aria-label="Main" class="hidden lg:block absolute left-1/2 -translate-x-1/2">
            <ul class="flex space-x-8 text-xs uppercase tracking-[0.2em] font-extrabold text-gray-500">
                <li><a href="#" class="nav-link hover:text-black transition-colors">Book</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Manage</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Experience</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Where We Fly</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Loyalty</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Help</a></li>
            </ul>
        </nav>
        <div class="flex items-center gap-6 z-10">
            <a href="/login" class="bg-black text-white px-8 py-2.5 rounded-full text-[10px] uppercase tracking-widest font-extrabold hover:bg-[--sky-blue] transition-all shadow-md">
                Login
            </a>
        </div>
    </header>

    <main id="main-content">
        <section class="relative min-h-screen flex flex-col items-center justify-center pt-32 px-6 overflow-hidden">
            <div class="absolute inset-0 -z-10 bg-slate-200">
                <img src="https://images.unsplash.com/photo-1542296332-2e4473faf563?auto=format&fit=crop&w=1920&q=80" alt="Jet wing above clouds" class="w-full h-full object-cover opacity-30 grayscale">
            </div>

            <div class="text-center mb-12">
                <h1 class="text-6xl md:text-8xl serif font-light leading-tight mb-4">
                    The Art of <span class="italic text-[--sky-blue]">Arrival</span>
                </h1>
                <p class="text-gray-400 uppercase tracking-[0.4em] text-[10px] font-bold">Bespoke Private Flight Charters</p>
            </div>

            <div class="float-card w-full max-w-5xl rounded-[40px] overflow-hidden">
                <div class="flex border-b border-gray-100 px-8 py-4 gap-8">
                    <button class="text-[10px] uppercase tracking-widest font-extrabold text-[--sky-blue] border-b-2 border-[--sky-blue] pb-1">Round Trip</button>
                    <button class="text-[10px] uppercase tracking-widest font-extrabold text-gray-300 hover:text-black transition-all pb-1">One Way</button>
                    <button class="text-[10px] uppercase tracking-widest font-extrabold text-gray-300 hover:text-black transition-all pb-1">Multi-City</button>
                </div>

                <form action="/search" method="GET" class="p-8 md:p-10 grid grid-cols-1 md:grid-cols-4 gap-8 items-end">
                    <div class="relative group">
                        <label for="origin" class="text-[10px] uppercase font-extrabold text-[--sky-blue] mb-2 block tracking-widest">Origin</label>
                        <input type="text" id="origin" name="origin" list="locations" placeholder="From where?" autocomplete="off" class="w-full bg-transparent border-b border-gray-200 pb-2 text-lg font-medium outline-none focus:border-[--sky-blue] transition-all placeholder:text-gray-300 custom-input" aria-required="true">
                    </div>

                    <div class="relative group">
                        <label for="destination" class="text-[10px] uppercase font-extrabold text-[--sky-blue] mb-2 block tracking-widest">Destination</label>
                        <input type="text" id="destination" name="destination" list="locations" placeholder="To where?" autocomplete="off" class="w-full bg-transparent border-b border-gray-200 pb-2 text-lg font-medium outline-none focus:border-[--sky-blue] transition-all placeholder:text-gray-300 custom-input" aria-required="true">
                    </div>

                    <div>
                        <label for="date" class="text-[10px] uppercase font-extrabold text-[--sky-blue] mb-2 block tracking-widest">Departure</label>
                        <input type="date" id="date" name="date" class="w-full bg-transparent border-b border-gray-200 pb-2 text-lg font-medium outline-none text-gray-400 cursor-pointer focus:border-[--sky-blue] transition-colors">
                    </div>

                    <button type="submit" class="w-full bg-[--charcoal] text-white py-5 rounded-2xl font-extrabold uppercase tracking-widest text-[10px] hover:bg-[--sky-blue] transition-all duration-500 active:scale-95 shadow-lg">
                        Find Availability
                    </button>

                    <datalist id="locations">
                        <option value="Amsterdam (AMS) — Netherlands">
                        <option value="Aspen (ASE) — United States">
                        <option value="Dubai (DXB) — United Arab Emirates">
                        <option value="Hong Kong (HKG) — China">
                        <option value="London (LHR) — United Kingdom">
                        <option value="Maldives (MLE) — Maldives">
                        <option value="New York (JFK) — United States">
                        <option value="Paris (CDG) — France">
                        <option value="Singapore (SIN) — Singapore">
                        <option value="Tokyo (HND) — Japan">
                    </datalist>
                </form>
            </div>
        </section>

        <section class="max-w-6xl mx-auto px-6 mt-4 mb-10 relative z-20">
