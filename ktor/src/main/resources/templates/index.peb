{% extends "base.html" %}

{% block title %}Aetheria | Sky-High Elegance{% endblock %}

{% block extra_css %}
        body { 
            background-color: var(--pearl); 
            color: var(--charcoal);
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        .float-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 1);
            box-shadow: 0 40px 100px -20px rgba(0, 40, 100, 0.1);
        }

        .nav-link {
            position: relative;
            padding-bottom: 6px;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 3px; 
            background-color: var(--sky-blue);
            transition: width 0.3s ease-in-out;
            border-radius: 3px;
        }
        .nav-link:hover::after { width: 100%; }
        
        .focus-within-ring:focus-within {
            outline: 3px solid var(--sky-blue);
            outline-offset: 4px;
        }

        .zoom-img { background-color: #E2E8F0; }
        .zoom-img img { transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
        .zoom-img:hover img { transform: scale(1.08); }

        .custom-input {
            background-image: linear-gradient(var(--sky-blue), var(--sky-blue));
            background-size: 0% 2px;
            background-repeat: no-repeat;
            background-position: bottom left;
            transition: background-size 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        .custom-input:focus { background-size: 100% 2px; }
        input::-webkit-calendar-picker-indicator { display: none !important; }

        @keyframes ambientGlow {
            0% { transform: scale(1) translate(0, 0); opacity: 0.1; }
            50% { transform: scale(1.2) translate(20px, -20px); opacity: 0.2; }
            100% { transform: scale(1) translate(0, 0); opacity: 0.1; }
        }
        .glow-blob { animation: ambientGlow 8s infinite alternate ease-in-out; }

        .banner-fallback { background: linear-gradient(to right, #1A1A1A, #2D3748); }

        .avatar-btn {
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 9999px;
            background-color: var(--sky-blue);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            box-shadow: 0 4px 14px rgba(0, 102, 255, 0.35);
            transition: background-color 0.2s, transform 0.2s;
            text-decoration: none;
        }
        .avatar-btn:hover {
            background-color: var(--charcoal);
            transform: scale(1.08);
        }
{% endblock %}

{% block body_classes %}relative{% endblock %}

{% block content %}
    <a href="#main-content" class="absolute -top-[100px] left-4 bg-[--sky-blue] text-white px-6 py-3 text-xs font-bold uppercase tracking-widest z-[1000] focus:top-4 transition-all duration-300 rounded-b-xl shadow-2xl">
        Skip to main content
    </a>

    <header class="w-full px-8 py-6 flex justify-between items-center fixed top-0 z-50 bg-white/60 backdrop-blur-lg border-b border-gray-100">
        <div class="text-2xl font-bold tracking-tighter serif text-[--sky-blue] z-10" aria-label="Aetheria Home">
            AETHERIA
        </div>
        <nav aria-label="Main" class="hidden lg:block absolute left-1/2 -translate-x-1/2">
            <ul class="flex space-x-8 text-xs uppercase tracking-[0.2em] font-extrabold text-gray-500">
                <li><a href="#" class="nav-link hover:text-black transition-colors">Book</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Manage</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Experience</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Where We Fly</a></li>
                <li><a href="#" class="nav-link hover:text-black transition-colors">Loyalty</a></li>
                <li class="relative" id="help-menu-wrapper">
    <button 
        id="help-btn"
        onclick="toggleHelpMenu()"
        class="nav-link hover:text-black transition-colors uppercase tracking-[0.2em] font-extrabold text-gray-500 hover:text-black bg-transparent border-none cursor-pointer text-xs"
        aria-haspopup="true"
        aria-expanded="false">
        Help
    </button>

    <div
        id="help-dropdown"
        class="hidden fixed left-0 right-0 bg-white border-t border-gray-100 shadow-2xl z-50"
        style="top: 73px;">

        <div class="max-w-7xl mx-auto px-8 py-12">

            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

                <!-- Column 1: Help & Contacts -->
                <div>
                    <a href="#" class="inline-flex items-center gap-2 text-sm font-extrabold text-[--charcoal] uppercase tracking-widest mb-6 hover:text-[--sky-blue] transition-colors group">
                        Help &amp; Contacts
                        <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                    <ul class="space-y-4">
                        <li>
                            <a href="#" class="flex items-center gap-2 text-sm text-gray-500 font-light hover:text-[--sky-blue] transition-colors group">
                                <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-[--sky-blue] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                                Changing or Cancelling
                            </a>
                        </li>
                        <li>
                            <a href="/complaints" class="flex items-center gap-2 text-sm text-gray-500 font-light hover:text-[--sky-blue] transition-colors group">
    <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-[--sky-blue] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    Feedback &amp; Complaints
</a>
                        </li>
                        <li>
                            <a href="#" class="flex items-center gap-2 text-sm text-gray-500 font-light hover:text-[--sky-blue] transition-colors group">
                                <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-[--sky-blue] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                                Lost Property
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Column 2: Flight Operations -->
                <div>
                    <a href="#" class="inline-flex items-center gap-2 text-sm font-extrabold text-[--charcoal] uppercase tracking-widest mb-6 hover:text-[--sky-blue] transition-colors group">
                        Flight Operations
                        <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                    <ul class="space-y-4">
                        <li>
                            <a href="#" class="flex items-center gap-2 text-sm text-gray-500 font-light hover:text-[--sky-blue] transition-colors group">
                                <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-[--sky-blue] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                                Recent Travel Updates
                            </a>
                        </li>
                        <li>
                            <a href="#" class="flex items-center gap-2 text-sm text-gray-500 font-light hover:text-[--sky-blue] transition-colors group">
                                <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-[--sky-blue] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                                Check Flight Status
                            </a>
                        </li>
                        <li>
                            <a href="#" class="flex items-center gap-2 text-sm text-gray-500 font-light hover:text-[--sky-blue] transition-colors group">
                                <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-[--sky-blue] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                                Before You Fly
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Column 3: Contact card -->
                <div class="bg-gray-50 rounded-[24px] p-8 flex flex-col justify-between">
                    <div>
                        <p class="text-[9px] uppercase tracking-[0.3em] text-[--sky-blue] font-bold mb-3">Need Assistance?</p>
                        <h3 class="text-xl serif text-[--charcoal] mb-3 leading-snug">Speak to our <span class="italic">Concierge Team</span></h3>
                        <p class="text-xs text-gray-400 font-light leading-relaxed">Available 24/7 for all Aetheria members worldwide.</p>
                    </div>
                    <a href="/complaints" class="mt-8 inline-flex items-center justify-center bg-[--charcoal] text-white px-6 py-3 rounded-full text-[10px] uppercase tracking-widest font-extrabold hover:bg-[--sky-blue] transition-all">
                        Contact Us
                    </a>
                </div>

            </div>
        </div>
    </div>
</li>
            </ul>
        </nav>
        <div class="flex items-center gap-6 z-10">
    {% if isLoggedIn %}
        <div class="relative" id="profile-menu-wrapper">
            <button 
                id="profile-btn"
                onclick="toggleProfileMenu()"
                class="avatar-btn"
                aria-label="Your profile"
                aria-haspopup="true"
                aria-expanded="false">
                {{ userInitials }}
            </button>

            <div 
                id="profile-dropdown"
                class="hidden absolute right-0 mt-3 w-72 bg-white rounded-[24px] shadow-2xl border border-gray-100 overflow-hidden z-50">
                
                <!-- Welcome header -->
                <div class="px-6 py-5 border-b border-gray-100 bg-gray-50/50">
                    <p class="text-[9px] uppercase tracking-[0.2em] text-[--sky-blue] font-bold mb-1">Welcome back</p>
                    <p class="text-base font-bold text-[--charcoal] serif">{{ userInitials }}</p>
                    <p class="text-[10px] text-gray-400 font-light mt-0.5 uppercase tracking-widest">AetherianFly Member</p>
                </div>

                <!-- Actions -->
                <div class="p-3">
                    <a href="/overview" 
                       class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 transition-colors group">
                        <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-[--sky-blue]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs font-extrabold uppercase tracking-widest text-[--charcoal] group-hover:text-[--sky-blue] transition-colors">My Overview</p>
                            <p class="text-[10px] text-gray-400 font-light">Bookings & profile</p>
                        </div>
                    </a>

                    <form action="/logout" method="POST" class="mt-1">
                        <button type="submit" 
                                class="w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-red-50 transition-colors group">
                            <div class="w-8 h-8 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                </svg>
                            </div>
                            <div class="text-left">
                                <p class="text-xs font-extrabold uppercase tracking-widest text-red-400 group-hover:text-red-500 transition-colors">Sign Out</p>
                                <p class="text-[10px] text-gray-400 font-light">End your session</p>
                            </div>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    {% else %}
        <a href="/login" class="bg-black text-white px-8 py-2.5 rounded-full text-[10px] uppercase tracking-widest font-extrabold hover:bg-[--sky-blue] transition-all shadow-md">
            Login
        </a>
