    async function updateComplaintStatus(complaintId) {
        const select = document.getElementById("complaint-status-" + complaintId);
        if (!select) return;

        const formData = new URLSearchParams();
        formData.append("status", select.value);

        try {
            const response = await fetch("/admin/complaints/" + complaintId + "/status", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded",
                    "Accept": "application/json"
                },
                body: formData.toString()
            });

            if (!response.ok) {
                throw new Error("Failed to update complaint status: " + response.status);
            }

            await loadComplaints();
            await refreshAllDashboardData();
        } catch (error) {
            showError(error);
        }
    }

    function extractAirportCode(nameCode) {
        if (!nameCode) return "";

        const parts = nameCode.toString().trim().split(/\s+/);
        return parts.length > 0 ? parts[parts.length - 1].toUpperCase() : "";
    }

    function toDatetimeLocalValue(value) {
        if (!value) return "";

        if (typeof value === "string") {
            return value.substring(0, 16);
        }

        return value.toString().substring(0, 16);
    }

    function openFlightEditModalByValues(
        flightId,
        flightCode,
        departureAirportNameCode,
        arrivalAirportNameCode,
        departureTime,
        arrivalTime,
        flightStatus,
        aircraftType
    ) {
        document.getElementById("editFlightId").value = flightId;
        document.getElementById("editFlightSubtitle").textContent =
            "Editing " + flightCode + " | " + departureAirportNameCode + " → " + arrivalAirportNameCode;

        document.getElementById("editDepartureAirportCode").value =
            extractAirportCode(departureAirportNameCode);

        document.getElementById("editArrivalAirportCode").value =
            extractAirportCode(arrivalAirportNameCode);

        document.getElementById("editDepartureTime").value =
            toDatetimeLocalValue(departureTime);

        document.getElementById("editArrivalTime").value =
            toDatetimeLocalValue(arrivalTime);

        document.getElementById("editFlightStatus").value = flightStatus || "SCHEDULED";
        document.getElementById("editAircraftType").value = aircraftType || "-";

        document.getElementById("flightEditError").classList.add("hidden");
        document.getElementById("flightEditModal").classList.remove("hidden");
        document.getElementById("flightEditModal").classList.add("flex");
    }

    function closeFlightEditModal() {
        document.getElementById("flightEditModal").classList.add("hidden");
        document.getElementById("flightEditModal").classList.remove("flex");
    }

    function showFlightEditError(message) {
        const errorBox = document.getElementById("flightEditError");
        errorBox.textContent = message;
        errorBox.classList.remove("hidden");
    }

    async function saveFlightEdit() {
        const flightId = document.getElementById("editFlightId").value;
        const departureAirportCode = document.getElementById("editDepartureAirportCode").value.trim().toUpperCase();
        const arrivalAirportCode = document.getElementById("editArrivalAirportCode").value.trim().toUpperCase();
        const departureTime = document.getElementById("editDepartureTime").value;
        const arrivalTime = document.getElementById("editArrivalTime").value;
        const status = document.getElementById("editFlightStatus").value;

        if (!flightId || !departureAirportCode || !arrivalAirportCode || !departureTime || !arrivalTime || !status) {
            showFlightEditError("Please fill in all required fields.");
            return;
        }

        try {
            const scheduleForm = new URLSearchParams();
            scheduleForm.append("departureAirportCode", departureAirportCode);
            scheduleForm.append("arrivalAirportCode", arrivalAirportCode);
            scheduleForm.append("departureTime", departureTime);
            scheduleForm.append("arrivalTime", arrivalTime);

            const scheduleResponse = await fetch("/admin/flights/" + flightId + "/update-schedule", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded",
                    "Accept": "application/json"
                },
                body: scheduleForm.toString()
            });

            if (!scheduleResponse.ok) {
                const text = await scheduleResponse.text();
                throw new Error("Failed to update flight schedule: " + scheduleResponse.status + " " + text);
            }

            const statusForm = new URLSearchParams();
            statusForm.append("status", status);

            const statusResponse = await fetch("/admin/flights/" + flightId + "/status", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded",
                    "Accept": "application/json"
                },
                body: statusForm.toString()
            });

            if (!statusResponse.ok) {
                const text = await statusResponse.text();
                throw new Error("Failed to update flight status: " + statusResponse.status + " " + text);
            }

            closeFlightEditModal();
            await loadFlightAvailability();
            await refreshAllDashboardData();
        } catch (error) {
            console.error(error);
            showFlightEditError(error.message || "Failed to update flight.");
        }
    }

    function loadCurrentSection() {
        if (currentSection === "reservations") {
            loadReservations();
        } else if (currentSection === "availability") {
            loadFlightAvailability();
        } else if (currentSection === "cancelledBookings") {
            loadCancelledBookings();
        } else if (currentSection === "cancelledFlights") {
            loadCancelledFlights();
        } else if (currentSection === "changes") {
            loadFlightChanges();
        } else if (currentSection === "bookingsReport") {
            loadBookingsPerFlight();
        } else if (currentSection === "routesReport") {
            loadPopularRoutes();
        } else if (currentSection === "timesReport") {
            loadPeakBookingTimes();
        } else if (currentSection === "complaints") {
            loadComplaints();
        }
    }

    document.addEventListener("DOMContentLoaded", async function () {
        await refreshAllDashboardData();
        await loadReservations(false);
        setActiveNav("nav-dashboard");
    });
</script>
{% endblock %}
