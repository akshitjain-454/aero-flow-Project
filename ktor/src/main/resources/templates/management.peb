{% extends "base.html" %}

{% block title %}Management Dashboard | Aetheria Admin{% endblock %}

{% block extra_css %}
    body {
        background-color: #f8fafc;
        color: #1e293b;
        margin: 0;
        overflow: hidden;
    }

    .admin-link.active {
        background-color: #eff6ff;
        color: var(--sky-blue);
        font-weight: 700;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .status-confirmed,
    .status-completed,
    .status-resolved,
    .status-closed,
    .status-scheduled,
    .status-arrived {
        background-color: #dcfce7;
        color: #166534;
    }

    .status-created,
    .status-pending,
    .status-open,
    .status-in_review,
    .status-delayed {
        background-color: #fef9c3;
        color: #854d0e;
    }

    .status-cancelled,
    .status-failed {
        background-color: #fee2e2;
        color: #991b1b;
    }

    .status-refunded {
        background-color: #dbeafe;
        color: #1d4ed8;
    }

    .admin-airport-dropdown {
        position: absolute;
        left: 0;
        right: 0;
        top: 100%;
        margin-top: 0.5rem;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 1rem;
        box-shadow: 0 20px 45px rgba(15, 23, 42, 0.16);
        z-index: 9999;
        max-height: 260px;
        overflow-y: auto;
    }

    .admin-airport-dropdown::-webkit-scrollbar {
        width: 4px;
    }

    .admin-airport-dropdown::-webkit-scrollbar-track {
        background: transparent;
    }

    .admin-airport-dropdown::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 99px;
    }

    .admin-airport-item {
        padding: 12px 14px;
        cursor: pointer;
        border-bottom: 1px solid #f1f5f9;
        font-size: 0.85rem;
        color: #1e293b;
        line-height: 1.4;
    }

    .admin-airport-item:last-child {
        border-bottom: none;
    }

    .admin-airport-item:hover,
    .admin-airport-item.active {
        background: #f8fafc;
    }

    .admin-airport-item .iata {
        display: inline-block;
        font-weight: 800;
        color: var(--sky-blue);
        margin-right: 8px;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
    }

    .admin-airport-item .sub {
        display: block;
        color: #94a3b8;
        font-size: 0.72rem;
        margin-top: 2px;
    }

    .admin-dropdown-empty,
    .admin-dropdown-loading {
        padding: 14px;
        font-size: 0.8rem;
        text-align: center;
        color: #94a3b8;
        font-style: italic;
    }

    .admin-date-dropdown {
        width: 320px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 1rem;
        box-shadow: 0 20px 45px rgba(15, 23, 42, 0.16);
        padding: 1rem;
    }

    .admin-cal-day {
        padding: 8px 4px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        line-height: 1;
    }

    .admin-cal-day:hover {
        background: #f1f5f9;
    }

    .admin-cal-day.admin-today {
        font-weight: 800;
        color: var(--sky-blue);
    }

    .admin-cal-day.admin-selected {
        background: var(--sky-blue);
        color: white;
        font-weight: 800;
    }

    .modal-field-label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--sky-blue);
    }
{% endblock %}

{% block content %}
<div class="flex h-screen w-full bg-slate-50 pt-20">

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col h-full shadow-sm z-10">
        <div class="p-6 border-b border-gray-100">
            <h2 class="text-xs uppercase tracking-widest font-bold text-gray-400 mb-1">Welcome back,</h2>
            <p class="text-sm font-bold text-[--sky-blue]">Staff Admin</p>
        </div>

        <nav class="flex-1 overflow-y-auto py-4">
            <ul class="space-y-1 px-3">
                <li>
                    <a id="nav-dashboard" href="javascript:void(0)" onclick="showDashboardOverview()"
                       class="admin-link active flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-colors">
                        Dashboard
                    </a>
                </li>

                <li>
                    <a id="nav-reservations" href="javascript:void(0)" onclick="loadReservations()"
                       class="admin-link flex items-center px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-black rounded-lg text-sm font-medium transition-colors">
                        Reservations
                    </a>
                </li>

                <li>
                    <a id="nav-flights" href="javascript:void(0)" onclick="loadFlightAvailability()"
                       class="admin-link flex items-center px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-black rounded-lg text-sm font-medium transition-colors">
                        Flights and Available
                    </a>
                </li>

                <li>
                    <a id="nav-changes" href="javascript:void(0)" onclick="loadFlightChanges()"
                       class="admin-link flex items-center px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-black rounded-lg text-sm font-medium transition-colors">
                        Changes and Cancellations
                    </a>
                </li>

                <li>
                    <a id="nav-report" href="javascript:void(0)" onclick="loadBookingsPerFlight()"
                       class="admin-link flex items-center px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-black rounded-lg text-sm font-medium transition-colors">
                        Reports
                    </a>
                </li>

                <li>
                    <a id="nav-complaints" href="javascript:void(0)" onclick="loadComplaints()"
                       class="admin-link flex items-center px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-black rounded-lg text-sm font-medium transition-colors">
                        Complaints
                    </a>
                </li>
            </ul>
        </nav>

        <div class="p-4 border-t border-gray-100">
            <form action="/logout" method="POST">
                <button type="submit"
                        class="w-full flex items-center justify-center px-4 py-2 border border-red-200 text-red-600 rounded-lg text-sm font-bold hover:bg-red-50 transition-colors">
                    Log out
                </button>
            </form>
        </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 overflow-y-auto p-8 h-full">
        <div class="max-w-7xl mx-auto pb-20">

            <!-- Dashboard -->
            <section id="dashboardOverview">
                <header class="mb-8 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
                    <div>
                        <h1 class="text-3xl font-bold text-[--charcoal] serif">Dashboard Overview</h1>
                        <p class="text-sm text-gray-500 mt-1">Live flight operations and management metrics</p>
                    </div>

                    <button onclick="refreshAllDashboardData()"
                            class="px-4 py-2 rounded-lg bg-[--sky-blue] text-white text-sm font-bold hover:opacity-90">
                        Refresh Overview
                    </button>
                </header>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Total Reservations</p>
                        <p id="overviewReservations" class="text-3xl font-bold text-[--charcoal]">-</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Cancelled Bookings</p>
                        <p id="overviewCancelledBookings" class="text-3xl font-bold text-red-500">-</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Flight Changes</p>
                        <p id="overviewChanges" class="text-3xl font-bold text-orange-400">-</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Available Seats</p>
                        <p id="overviewAvailableSeats" class="text-3xl font-bold text-[--sky-blue]">-</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="text-sm uppercase tracking-widest font-bold text-[--charcoal] mb-4">
                            Top Popular Routes
                        </h3>
                        <div id="popularRoutesBox" class="space-y-3 text-sm text-gray-600">
                            Loading...
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="text-sm uppercase tracking-widest font-bold text-[--charcoal] mb-4">
                            Peak Booking Times
                        </h3>
                        <div id="peakTimesBox" class="space-y-3 text-sm text-gray-600">
                            Loading...
                        </div>
                    </div>
                </div>
            </section>

            <!-- Management panel -->
            <section id="managementPanel" class="mt-10 bg-white border border-gray-100 rounded-2xl shadow-sm overflow-visible">
                <div class="px-6 py-5 border-b border-gray-100 flex flex-col xl:flex-row xl:items-end xl:justify-between gap-4">
                    <div>
                        <h2 id="sectionTitle" class="text-2xl font-bold text-[--charcoal] serif">Reservations</h2>
                        <p id="sectionDescription" class="text-sm text-gray-500 mt-1">
                            Showing all reservations made through the system.
                        </p>
                    </div>

                    <!-- Enhanced filter box -->
                    <div id="filterBox" class="flex flex-wrap gap-3 items-end">

                        <!-- Origin -->
                        <div class="relative w-56" id="filterFromWrapper">
                            <label class="text-[10px] uppercase font-bold text-[--sky-blue] tracking-widest block mb-1">
                                Origin
                            </label>

                            <input id="filterFrom" type="hidden">

                            <input id="filterFromDisplay"
                                   type="text"
                                   placeholder="From where?"
                                   autocomplete="off"
                                   class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm outline-none focus:border-[--sky-blue]">

                            <div id="filterFromResults" class="admin-airport-dropdown hidden"></div>
                        </div>

                        <!-- Swap -->
                        <button type="button"
                                id="adminSwapBtn"
                                class="px-3 py-2 border border-gray-200 rounded-lg text-sm font-bold hover:bg-gray-50">
                            ⇄
                        </button>

                        <!-- Destination -->
                        <div class="relative w-56" id="filterToWrapper">
                            <label class="text-[10px] uppercase font-bold text-[--sky-blue] tracking-widest block mb-1">
                                Destination
                            </label>

                            <input id="filterTo" type="hidden">

                            <input id="filterToDisplay"
                                   type="text"
                                   placeholder="To where?"
                                   autocomplete="off"
                                   class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm outline-none focus:border-[--sky-blue]">

                            <div id="filterToResults" class="admin-airport-dropdown hidden"></div>
                        </div>

                        <!-- Date -->
                        <div class="relative w-48" id="filterDateWrapper">
                            <label class="text-[10px] uppercase font-bold text-[--sky-blue] tracking-widest block mb-1">
                                Departure
                            </label>

                            <input id="filterDate" type="hidden">

                            <button type="button"
                                    id="filterDateDisplay"
                                    class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm text-left bg-white hover:bg-gray-50">
                                <span id="filterDateText" class="text-gray-400">Any date</span>
                            </button>
                        </div>

                        <!-- Reservation status -->
                        <select id="filterStatus"
                                class="px-3 py-2 border border-gray-200 rounded-lg text-sm hidden">
                            <option value="">All Status</option>
                            <option value="CREATED">CREATED</option>
                            <option value="CONFIRMED">CONFIRMED</option>
                            <option value="CANCELLED">CANCELLED</option>
                        </select>

                        <button onclick="loadCurrentSection()"
                                class="px-4 py-2 bg-[--charcoal] text-white rounded-lg text-sm font-bold hover:opacity-90">
                            Apply
                        </button>

                        <button onclick="clearFilters()"
                                class="px-4 py-2 bg-white border border-gray-200 text-gray-700 rounded-lg text-sm font-bold hover:bg-gray-50">
                            Clear
                        </button>
                    </div>
                </div>

                <!-- Calendar dropdown -->
                <div id="adminDateDropdown"
                     class="admin-date-dropdown hidden"
                     style="position: fixed; z-index: 99999;">
                    <div class="flex justify-between items-center mb-4">
                        <button type="button" id="adminPrevMonth"
                                class="w-8 h-8 rounded-full hover:bg-gray-100 text-gray-500">
                            ←
                        </button>

                        <span id="adminMonthLabel" class="font-bold text-sm text-gray-700"></span>

                        <button type="button" id="adminNextMonth"
                                class="w-8 h-8 rounded-full hover:bg-gray-100 text-gray-500">
                            →
                        </button>
                    </div>

                    <div class="grid grid-cols-7 text-xs text-gray-400 mb-2 text-center gap-1">
                        <div>Mo</div><div>Tu</div><div>We</div><div>Th</div><div>Fr</div><div>Sa</div><div>Su</div>
                    </div>

                    <div id="adminCalendarGrid" class="grid grid-cols-7 gap-1 text-center text-sm"></div>
                </div>

                <!-- Report switcher -->
                <div id="reportSwitcher" class="px-6 py-4 border-b border-gray-100 hidden">
                    <div class="flex flex-wrap gap-2">
                        <button onclick="loadBookingsPerFlight()"
                                class="px-4 py-2 rounded-lg bg-blue-50 text-[--sky-blue] text-sm font-bold">
                            Bookings Per Flight
                        </button>
                        <button onclick="loadPopularRoutes()"
                                class="px-4 py-2 rounded-lg bg-gray-50 text-gray-700 text-sm font-bold">
                            Popular Routes
                        </button>
                        <button onclick="loadPeakBookingTimes()"
                                class="px-4 py-2 rounded-lg bg-gray-50 text-gray-700 text-sm font-bold">
                            Peak Times
                        </button>
                    </div>
                </div>

                <!-- Changes switcher -->
                <div id="changesSwitcher" class="px-6 py-4 border-b border-gray-100 hidden">
                    <div class="flex flex-wrap gap-2">
                        <button onclick="loadFlightChanges()"
                                class="px-4 py-2 rounded-lg bg-blue-50 text-[--sky-blue] text-sm font-bold">
                            Flight Changes
                        </button>
                        <button onclick="loadCancelledBookings()"
                                class="px-4 py-2 rounded-lg bg-gray-50 text-gray-700 text-sm font-bold">
                            Cancelled Bookings
                        </button>
                        <button onclick="loadCancelledFlights()"
                                class="px-4 py-2 rounded-lg bg-gray-50 text-gray-700 text-sm font-bold">
                            Cancelled Flights
                        </button>
                    </div>
                </div>

                <div id="summaryBox" class="px-6 py-4 bg-gray-50 border-b border-gray-100 text-sm text-gray-600">
                    Loading summary...
                </div>

                <div id="loadingMessage" class="p-8 text-center text-gray-500 hidden">
                    Loading data...
                </div>

                <div id="errorMessage" class="p-8 text-center text-red-600 hidden">
                    Failed to load data.
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead id="tableHead" class="bg-gray-50 text-gray-600 uppercase text-xs"></thead>
                        <tbody id="tableBody" class="divide-y divide-gray-100"></tbody>
                    </table>
                </div>
            </section>

        </div>
    </main>
</div>

<!-- Edit flight modal -->
<div id="editFlightModal"
     class="fixed inset-0 bg-black/40 hidden items-center justify-center z-[99999] px-4">

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl overflow-visible">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-start gap-4">
            <div>
                <h3 class="text-xl font-bold text-[--charcoal] serif">Edit Flight</h3>
                <p id="editFlightCodeText" class="text-sm text-gray-500 mt-1">Update flight route, times, and status.</p>
            </div>

            <button type="button"
                    onclick="closeEditFlightModal()"
                    class="w-9 h-9 rounded-full hover:bg-gray-100 text-gray-500 text-xl leading-none">
                ×
            </button>
        </div>

        <div class="p-6 space-y-5">
            <input type="hidden" id="editFlightId">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="relative" id="editDepartureWrapper">
                    <label class="modal-field-label">Departure Airport</label>
                    <input id="editDepartureAirportCode"
                           type="text"
                           maxlength="3"
                           autocomplete="off"
                           class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm uppercase outline-none focus:border-[--sky-blue]"
                           placeholder="LBA">
                    <div id="editDepartureResults" class="admin-airport-dropdown hidden"></div>
                </div>

                <div class="relative" id="editArrivalWrapper">
                    <label class="modal-field-label">Arrival Airport</label>
                    <input id="editArrivalAirportCode"
                           type="text"
                           maxlength="3"
                           autocomplete="off"
                           class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm uppercase outline-none focus:border-[--sky-blue]"
                           placeholder="DXB">
                    <div id="editArrivalResults" class="admin-airport-dropdown hidden"></div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="modal-field-label">Departure Time</label>
                    <input id="editDepartureTime"
                           type="datetime-local"
                           class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm outline-none focus:border-[--sky-blue]">
                </div>

                <div>
                    <label class="modal-field-label">Arrival Time</label>
                    <input id="editArrivalTime"
                           type="datetime-local"
                           class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm outline-none focus:border-[--sky-blue]">
                </div>
            </div>

            <div>
                <label class="modal-field-label">Flight Status</label>
                <select id="editFlightStatus"
                        class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm outline-none focus:border-[--sky-blue]">
                    <option value="SCHEDULED">SCHEDULED</option>
                    <option value="DELAYED">DELAYED</option>
                    <option value="ARRIVED">ARRIVED</option>
                    <option value="CANCELLED">CANCELLED</option>
                </select>
            </div>

            <div id="editFlightError"
                 class="hidden text-sm text-red-600 bg-red-50 border border-red-100 rounded-lg px-3 py-2">
            </div>
        </div>

        <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3">
            <button type="button"
                    onclick="closeEditFlightModal()"
                    class="px-4 py-2 bg-white border border-gray-200 text-gray-700 rounded-lg text-sm font-bold hover:bg-gray-50">
                Cancel
            </button>

            <button type="button"
                    onclick="submitFlightEdit()"
                    class="px-4 py-2 bg-[--charcoal] text-white rounded-lg text-sm font-bold hover:opacity-90">
                Save Changes
            </button>
        </div>
    </div>
</div>

<script>
    let currentSection = "reservations";
    window.adminFlightRows = window.adminFlightRows || {};

    function setActiveNav(navId) {
        document.querySelectorAll(".admin-link").forEach(link => {
            link.classList.remove("active");
            link.classList.add("text-gray-600");
        });

        const active = document.getElementById(navId);

        if (active) {
            active.classList.add("active");
            active.classList.remove("text-gray-600");
        }
    }

    function scrollToPanel() {
        const panel = document.getElementById("managementPanel");

        if (panel) {
            panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }
    }

    function showDashboardOverview() {
        setActiveNav("nav-dashboard");
        window.scrollTo({ top: 0, behavior: "smooth" });
        refreshAllDashboardData();
    }

    function setSection(section, title, description, options = {}) {
        currentSection = section;

        document.getElementById("sectionTitle").textContent = title;
        document.getElementById("sectionDescription").textContent = description;

        const filterBox = document.getElementById("filterBox");
        const statusFilter = document.getElementById("filterStatus");
        const reportSwitcher = document.getElementById("reportSwitcher");
        const changesSwitcher = document.getElementById("changesSwitcher");

        const sectionsWithFilters = [
            "reservations",
            "availability",
            "cancelledBookings",
            "cancelledFlights",
            "changes"
        ];

        if (sectionsWithFilters.includes(section)) {
            filterBox.classList.remove("hidden");
        } else {
            filterBox.classList.add("hidden");
        }

        if (section === "reservations") {
            statusFilter.classList.remove("hidden");
        } else {
            statusFilter.classList.add("hidden");
        }

        if (options.showReports) {
            reportSwitcher.classList.remove("hidden");
        } else {
            reportSwitcher.classList.add("hidden");
        }

        if (options.showChanges) {
            changesSwitcher.classList.remove("hidden");
        } else {
            changesSwitcher.classList.add("hidden");
        }
    }

    function showLoading() {
        document.getElementById("loadingMessage").classList.remove("hidden");
        document.getElementById("errorMessage").classList.add("hidden");
        document.getElementById("tableHead").innerHTML = "";
        document.getElementById("tableBody").innerHTML = "";
        document.getElementById("summaryBox").textContent = "Loading summary...";
    }

    function hideLoading() {
        document.getElementById("loadingMessage").classList.add("hidden");
    }

    function showError(error) {
        console.error(error);
        hideLoading();
        document.getElementById("errorMessage").classList.remove("hidden");
        document.getElementById("summaryBox").textContent =
            "Could not load this section. Check browser Console or Network tab.";
    }

    function escapeHtml(value) {
        if (value === null || value === undefined) return "-";

        return value.toString()
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    function formatDateTime(value) {
        if (!value) return "-";

        if (typeof value === "string") {
            return value.replace("T", " ").substring(0, 16);
        }

        return value.toString();
    }

    function formatMoney(value) {
        if (value === null || value === undefined || value === "") return "-";
        return "£" + value;
    }

    function statusBadge(status) {
        if (!status) return "-";

        const className = "status-" + status.toString().toLowerCase();

        return `<span class="status-badge ${className}">
            ${escapeHtml(status)}
        </span>`;
    }

    function getResults(data) {
        if (!data) return [];
        if (Array.isArray(data)) return data;
        return data.results || [];
    }

    function renderTable(headers, rows) {
        const head = document.getElementById("tableHead");
        const body = document.getElementById("tableBody");

        head.innerHTML = `
            <tr>
                ${headers.map(header => `
                    <th class="px-6 py-3 font-black tracking-widest whitespace-nowrap">
                        ${escapeHtml(header)}
                    </th>
                `).join("")}
            </tr>
        `;

        if (!rows || rows.length === 0) {
            body.innerHTML = `
                <tr>
                    <td colspan="${headers.length}" class="px-6 py-10 text-center text-gray-400">
                        No data found.
                    </td>
                </tr>
            `;
            return;
        }

        body.innerHTML = rows.join("");
    }

    function setSummary(text) {
        document.getElementById("summaryBox").textContent = text;
    }

    async function fetchData(url) {
        showLoading();

        const response = await fetch(url, {
            headers: {
                "Accept": "application/json"
            }
        });

        if (!response.ok) {
            throw new Error("Request failed: " + response.status + " " + url);
        }

        const data = await response.json();
        hideLoading();

        return data;
    }

    async function fetchSilent(url) {
        try {
            const response = await fetch(url, {
                headers: {
                    "Accept": "application/json"
                }
            });

            if (!response.ok) return null;

            return await response.json();
        } catch (error) {
            console.error(error);
            return null;
        }
    }

    function getAirportCodeFilter(hiddenInputId, displayInputId) {
        const hiddenInput = document.getElementById(hiddenInputId);
        const displayInput = document.getElementById(displayInputId);

        const hiddenValue = hiddenInput ? hiddenInput.value.trim().toUpperCase() : "";

        if (hiddenValue) return hiddenValue;

        const displayValue = displayInput ? displayInput.value.trim().toUpperCase() : "";
        const match = displayValue.match(/^[A-Z]{3}/);

        return match ? match[0] : "";
    }

    function getFilterQuery(includeStatus) {
        const params = new URLSearchParams();

        const from = getAirportCodeFilter("filterFrom", "filterFromDisplay");
        const to = getAirportCodeFilter("filterTo", "filterToDisplay");
        const date = document.getElementById("filterDate").value;
        const status = document.getElementById("filterStatus").value;

        if (from) params.append("from", from);
        if (to) params.append("to", to);
        if (date) params.append("date", date);
        if (includeStatus && status) params.append("status", status);

        const query = params.toString();

        return query ? "?" + query : "";
    }

    function clearFilters() {
        document.getElementById("filterFrom").value = "";
        document.getElementById("filterTo").value = "";
        document.getElementById("filterDate").value = "";
        document.getElementById("filterStatus").value = "";

        if (window.resetAdminEnhancedFilters) {
            window.resetAdminEnhancedFilters();
        }

        loadCurrentSection();
    }

    function loadCurrentSection() {
        if (currentSection === "reservations") return loadReservations(false);
        if (currentSection === "availability") return loadFlightAvailability(false);
        if (currentSection === "cancelledBookings") return loadCancelledBookings(false);
        if (currentSection === "cancelledFlights") return loadCancelledFlights(false);
        if (currentSection === "changes") return loadFlightChanges(false);
        if (currentSection === "bookingsPerFlight") return loadBookingsPerFlight(false);
        if (currentSection === "popularRoutes") return loadPopularRoutes(false);
        if (currentSection === "peakBookingTimes") return loadPeakBookingTimes(false);
        if (currentSection === "complaints") return loadComplaints(false);
    }

    async function refreshAllDashboardData() {
        const reservationsData = await fetchSilent("/admin/reservations");
        const cancelledData = await fetchSilent("/admin/bookings/cancelled");
        const changesData = await fetchSilent("/admin/flights/changes");
        const availabilityData = await fetchSilent("/admin/flights/availability");
        const popularRoutesData = await fetchSilent("/admin/reports/most-popular-routes");
        const peakTimesData = await fetchSilent("/admin/reports/peak-booking-times");

        const reservations = getResults(reservationsData);
        const cancelled = getResults(cancelledData);
        const changes = getResults(changesData);
        const availability = getResults(availabilityData);
        const popularRoutes = getResults(popularRoutesData);
        const peakTimes = getResults(peakTimesData);

        document.getElementById("overviewReservations").textContent = reservations.length;
        document.getElementById("overviewCancelledBookings").textContent = cancelled.length;
        document.getElementById("overviewChanges").textContent = changes.length;

        const availableSeats = availability.reduce((sum, item) => {
            return sum + Number(item.availableSeats || 0);
        }, 0);

        document.getElementById("overviewAvailableSeats").textContent = availableSeats;

        document.getElementById("popularRoutesBox").innerHTML = popularRoutes.slice(0, 5).map(item => `
            <div class="flex justify-between gap-4 border-b border-gray-100 pb-2">
                <span>${escapeHtml(item.departureAirportNameCode)} → ${escapeHtml(item.arrivalAirportNameCode)}</span>
                <strong>${escapeHtml(item.bookingCount)}</strong>
            </div>
        `).join("") || `<p class="text-gray-400">No route data.</p>`;

        document.getElementById("peakTimesBox").innerHTML = peakTimes.slice(0, 5).map(item => `
            <div class="flex justify-between gap-4 border-b border-gray-100 pb-2">
                <span>${escapeHtml(item.bookingHour)}</span>
                <strong>${escapeHtml(item.bookingCount)}</strong>
            </div>
        `).join("") || `<p class="text-gray-400">No peak time data.</p>`;
    }

