                    <td class="px-6 py-4">${statusBadge(item.flightStatus)}</td>
                    <td class="px-6 py-4">${escapeHtml(item.totalSeats)}</td>
                    <td class="px-6 py-4 font-bold text-red-600">${escapeHtml(item.bookedSeats)}</td>
                    <td class="px-6 py-4 font-bold text-green-600">${escapeHtml(item.availableSeats)}</td>
                    <td class="px-6 py-4">
                        <button onclick="openFlightEditModalByValues(
                                    ${Number(item.flightId)},
                                    '${escapeJsString(item.flightCode)}',
                                    '${escapeJsString(item.departureAirportNameCode)}',
                                    '${escapeJsString(item.arrivalAirportNameCode)}',
                                    '${escapeJsString(item.departureTime)}',
                                    '${escapeJsString(item.arrivalTime)}',
                                    '${escapeJsString(item.flightStatus)}',
                                    '${escapeJsString(item.aircraftType)}'
                                )"
                                class="px-3 py-2 bg-[--sky-blue] text-white rounded-lg text-sm font-bold hover:opacity-90 whitespace-nowrap">
                            Edit
                        </button>
                    </td>
                </tr>
            `);

            setSummary(`Flights shown: ${results.length} | Booked seats: ${totalBooked} | Available seats: ${totalAvailable}`);
            renderTable(
                ["Flight", "Aircraft", "From", "To", "Departure", "Arrival", "Status", "Total Seats", "Booked", "Available", "Action"],
                rows
            );
        } catch (error) {
            showError(error);
        }
    }

