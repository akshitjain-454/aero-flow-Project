                                            <div class="font-bold text-[--sky-blue] mb-1">Current Reply</div>
                                            <div>${escapeHtml(item.adminReply)}</div>
                                            <div class="text-xs text-gray-400 mt-2">
                                                ${item.repliedByName ? "By " + escapeHtml(item.repliedByName) + " · " : ""}
                                                ${formatDateTime(item.repliedAt)}
                                            </div>
                                        </div>
                                    `
                                    : `<div class="text-xs text-gray-400 italic mb-3">No reply yet.</div>`
                            }

                            <textarea id="complaint-reply-${Number(item.id)}"
                                    rows="4"
                                    placeholder="Write or update admin reply..."
                                    class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm outline-none focus:border-[--sky-blue]">${hasReply ? escapeHtml(item.adminReply) : ""}</textarea>
                        </td>

                        <td class="px-6 py-4 min-w-56">
                            <div class="space-y-3">
                                <select id="complaint-status-${Number(item.id)}"
                                        class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm">
                                    <option value="OPEN" ${item.status === "OPEN" ? "selected" : ""}>Open</option>
                                    <option value="IN_REVIEW" ${item.status === "IN_REVIEW" ? "selected" : ""}>In Review</option>
                                    <option value="RESOLVED" ${item.status === "RESOLVED" ? "selected" : ""}>Resolved</option>
                                </select>

                                <button onclick="handleComplaint(${Number(item.id)})"
                                        class="w-full px-3 py-2 bg-[--sky-blue] text-white rounded-lg text-sm font-bold hover:opacity-90">
                                    Save Response
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });

            setSummary(`Complaints shown: ${results.length}`);
            renderTable(
                ["ID", "Customer", "Complaint", "Status", "Admin Reply", "Handle"],
                rows
            );
        } catch (error) {
            showError(error);
        }
    }

    async function handleComplaint(complaintId) {
        const statusSelect = document.getElementById("complaint-status-" + complaintId);
        const replyBox = document.getElementById("complaint-reply-" + complaintId);

        if (!statusSelect || !replyBox) return;

        const formData = new URLSearchParams();
        formData.append("status", statusSelect.value);
        formData.append("reply", replyBox.value.trim());

        try {
            const response = await fetch("/admin/complaints/" + complaintId + "/handle", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded",
                    "Accept": "application/json"
                },
                body: formData.toString()
            });

            if (!response.ok) {
                const text = await response.text();
                throw new Error(text || "Failed to handle complaint: " + response.status);
            }

            await loadComplaints(false);
            await refreshAllDashboardData();
        } catch (error) {
            showError(error);
        }
    }

    function extractAirportCode(nameCode) {
        if (!nameCode) return "";

        const match = nameCode.toString().trim().toUpperCase().match(/([A-Z]{3})$/);
        return match ? match[1] : "";
    }

    function toDateTimeLocal(value) {
        if (!value) return "";

        return value.toString().replace(" ", "T").substring(0, 16);
    }

    function showEditFlightError(message) {
        const box = document.getElementById("editFlightError");
        box.textContent = message;
        box.classList.remove("hidden");
    }

    function hideEditFlightError() {
        const box = document.getElementById("editFlightError");
        box.textContent = "";
        box.classList.add("hidden");
    }

    function openEditFlightModal(flightId) {
        const flight = window.adminFlightRows[flightId];

        if (!flight) {
            alert("Flight data not found. Please refresh the table.");
            return;
        }

        hideEditFlightError();

        document.getElementById("editFlightId").value = flight.flightId;
        document.getElementById("editFlightCodeText").textContent =
            `${flight.flightCode} — ${flight.departureAirportNameCode} to ${flight.arrivalAirportNameCode}`;

        document.getElementById("editDepartureAirportCode").value =
            extractAirportCode(flight.departureAirportNameCode);

        document.getElementById("editArrivalAirportCode").value =
            extractAirportCode(flight.arrivalAirportNameCode);

        document.getElementById("editDepartureTime").value =
            toDateTimeLocal(flight.departureTime);

        document.getElementById("editArrivalTime").value =
            toDateTimeLocal(flight.arrivalTime);

        document.getElementById("editFlightStatus").value =
            flight.flightStatus || flight.status || "SCHEDULED";

        const modal = document.getElementById("editFlightModal");
        modal.classList.remove("hidden");
        modal.classList.add("flex");
    }

    function closeEditFlightModal() {
        const modal = document.getElementById("editFlightModal");
        modal.classList.add("hidden");
        modal.classList.remove("flex");
    }

    async function readErrorMessage(response) {
        const text = await response.text();

        try {
            const json = JSON.parse(text);
            return json.error || json.message || text;
        } catch (error) {
            return text;
        }
    }

    async function submitFlightEdit() {
        hideEditFlightError();

        const flightId = document.getElementById("editFlightId").value;
        const departureAirportCode = document.getElementById("editDepartureAirportCode").value.trim().toUpperCase();
        const arrivalAirportCode = document.getElementById("editArrivalAirportCode").value.trim().toUpperCase();
        const departureTime = document.getElementById("editDepartureTime").value;
        const arrivalTime = document.getElementById("editArrivalTime").value;
        const status = document.getElementById("editFlightStatus").value;
        const originalFlight = window.adminFlightRows[flightId];

        if (!flightId || !departureAirportCode || !arrivalAirportCode || !departureTime || !arrivalTime) {
            showEditFlightError("Please fill in departure airport, arrival airport, departure time, and arrival time.");
            return;
        }

        if (departureAirportCode.length !== 3 || arrivalAirportCode.length !== 3) {
            showEditFlightError("Airport codes must be 3 letters, for example LBA or DXB.");
            return;
        }

        const originalDepartureCode = originalFlight ? extractAirportCode(originalFlight.departureAirportNameCode) : "";
        const originalArrivalCode = originalFlight ? extractAirportCode(originalFlight.arrivalAirportNameCode) : "";
        const originalDepartureTime = originalFlight ? toDateTimeLocal(originalFlight.departureTime) : "";
        const originalArrivalTime = originalFlight ? toDateTimeLocal(originalFlight.arrivalTime) : "";
        const originalStatus = originalFlight ? (originalFlight.flightStatus || originalFlight.status || "") : "";

        const scheduleChanged =
            departureAirportCode !== originalDepartureCode ||
            arrivalAirportCode !== originalArrivalCode ||
            departureTime !== originalDepartureTime ||
            arrivalTime !== originalArrivalTime;

        const statusChanged = status !== originalStatus;

        if (!scheduleChanged && !statusChanged) {
            showEditFlightError("No changes to save.");
            return;
        }

        try {
            if (scheduleChanged) {
                const scheduleBody = new URLSearchParams();
                scheduleBody.append("departureAirportCode", departureAirportCode);
                scheduleBody.append("arrivalAirportCode", arrivalAirportCode);
                scheduleBody.append("departureTime", departureTime);
                scheduleBody.append("arrivalTime", arrivalTime);

                const scheduleResponse = await fetch(`/admin/flights/${flightId}/update-schedule`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded",
                        "Accept": "application/json"
                    },
                    body: scheduleBody.toString()
                });

                if (!scheduleResponse.ok) {
                    throw new Error(await readErrorMessage(scheduleResponse) || "Failed to update flight schedule.");
                }
            }

            if (statusChanged) {
                const statusBody = new URLSearchParams();
                statusBody.append("status", status);

                const statusResponse = await fetch(`/admin/flights/${flightId}/status`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded",
                        "Accept": "application/json"
                    },
                    body: statusBody.toString()
                });

                if (!statusResponse.ok) {
                    throw new Error(await readErrorMessage(statusResponse) || "Failed to update flight status.");
                }
            }

            closeEditFlightModal();
            await loadFlightAvailability(false);
            await refreshAllDashboardData();
        } catch (error) {
            console.error(error);
            showEditFlightError(error.message || "Failed to update flight.");
        }
    }

    // Airport autocomplete and custom calendar
    (function () {
        const adminDateDropdown = document.getElementById("adminDateDropdown");

        if (adminDateDropdown) {
            document.body.appendChild(adminDateDropdown);
        }

        const airportConfigs = [
            {
                key: "FilterFrom",
                wrapperId: "filterFromWrapper",
                displayId: "filterFromDisplay",
                codeId: "filterFrom",
                resultsId: "filterFromResults",
                displayMode: "full"
            },
            {
                key: "FilterTo",
                wrapperId: "filterToWrapper",
                displayId: "filterToDisplay",
                codeId: "filterTo",
                resultsId: "filterToResults",
                displayMode: "full"
            },
            {
                key: "EditDeparture",
                wrapperId: "editDepartureWrapper",
                displayId: "editDepartureAirportCode",
                codeId: "editDepartureAirportCode",
                resultsId: "editDepartureResults",
                displayMode: "code"
            },
            {
                key: "EditArrival",
                wrapperId: "editArrivalWrapper",
                displayId: "editArrivalAirportCode",
                codeId: "editArrivalAirportCode",
                resultsId: "editArrivalResults",
                displayMode: "code"
            }
        ];

        const airportTimers = {};
        const airportActiveIndex = {};

        airportConfigs.forEach(config => {
            airportActiveIndex[config.key] = -1;

            const display = document.getElementById(config.displayId);
            const codeInput = document.getElementById(config.codeId);
            const dropdown = document.getElementById(config.resultsId);

            if (!display || !codeInput || !dropdown) return;

            display.addEventListener("input", () => {
                clearTimeout(airportTimers[config.key]);

                if (config.displayMode === "full" && codeInput !== display) {
                    codeInput.value = "";
                }

                if (config.displayMode === "code") {
                    display.value = display.value.toUpperCase();
                }

                const query = display.value.trim();

                if (query.length < 2) {
                    closeAirportDropdown(config);
                    return;
                }

                showAirportLoading(config);

                airportTimers[config.key] = setTimeout(() => {
                    fetchAdminAirports(config, query);
                }, 250);
            });

            display.addEventListener("keydown", event => {
                const items = dropdown.querySelectorAll(".admin-airport-item");

                if (!items.length) return;

                if (event.key === "ArrowDown") {
                    event.preventDefault();
                    airportActiveIndex[config.key]++;
                } else if (event.key === "ArrowUp") {
                    event.preventDefault();
                    airportActiveIndex[config.key]--;
                } else if (event.key === "Enter") {
                    event.preventDefault();

                    if (airportActiveIndex[config.key] >= 0) {
                        items[airportActiveIndex[config.key]].click();
                    }

                    return;
                } else {
                    return;
                }

                airportActiveIndex[config.key] = Math.max(
                    0,
                    Math.min(airportActiveIndex[config.key], items.length - 1)
                );

                updateAirportActive(config, items);
            });
        });

        async function fetchAdminAirports(config, query) {
            try {
                const response = await fetch(`/airports?search=${encodeURIComponent(query)}`, {
                    headers: {
                        "Accept": "application/json"
                    }
                });

                if (!response.ok) {
                    throw new Error("Airport search failed");
                }

                const airports = await response.json();
                renderAirportDropdown(config, airports);
            } catch (error) {
                console.error(error);
                renderAirportError(config);
            }
        }

        function renderAirportDropdown(config, airports) {
            const dropdown = document.getElementById(config.resultsId);

            dropdown.innerHTML = "";
            airportActiveIndex[config.key] = 0;

            if (!airports || airports.length === 0) {
                dropdown.innerHTML = `<div class="admin-dropdown-empty">No airports found</div>`;
                dropdown.classList.remove("hidden");
                return;
            }

            airports.forEach(airport => {
                const item = document.createElement("div");
                item.className = "admin-airport-item";

                item.innerHTML = `
                    <span class="iata">${escapeHtml(airport.code)}</span>
                    ${escapeHtml(airport.name)}
                    <span class="sub">${escapeHtml(airport.city)}, ${escapeHtml(airport.country)}</span>
                `;

                item.addEventListener("mousedown", event => {
                    event.preventDefault();
                    selectAdminAirport(config, airport);
                });

                dropdown.appendChild(item);
            });

            updateAirportActive(config, dropdown.querySelectorAll(".admin-airport-item"));
            dropdown.classList.remove("hidden");
        }

        function selectAdminAirport(config, airport) {
            const display = document.getElementById(config.displayId);
            const codeInput = document.getElementById(config.codeId);

            codeInput.value = airport.code;

            if (config.displayMode === "code") {
                display.value = airport.code;
            } else {
                display.value = `${airport.code} – ${airport.name}`;
            }

            closeAirportDropdown(config);
        }

        function closeAirportDropdown(config) {
            const dropdown = document.getElementById(config.resultsId);

            if (!dropdown) return;

            dropdown.classList.add("hidden");
            dropdown.innerHTML = "";
        }

        function showAirportLoading(config) {
            const dropdown = document.getElementById(config.resultsId);
            dropdown.innerHTML = `<div class="admin-dropdown-loading">Searching…</div>`;
            dropdown.classList.remove("hidden");
        }

        function renderAirportError(config) {
            const dropdown = document.getElementById(config.resultsId);
            dropdown.innerHTML = `<div class="admin-dropdown-empty">Error loading airports</div>`;
            dropdown.classList.remove("hidden");
        }

        function updateAirportActive(config, items) {
            items.forEach((item, index) => {
                item.classList.toggle("active", index === airportActiveIndex[config.key]);
            });
        }

        document.addEventListener("click", event => {
            airportConfigs.forEach(config => {
                const wrapper = document.getElementById(config.wrapperId);

                if (wrapper && !wrapper.contains(event.target)) {
                    closeAirportDropdown(config);
                }
            });
        });

        const adminSwapBtn = document.getElementById("adminSwapBtn");

        if (adminSwapBtn) {
            adminSwapBtn.addEventListener("click", () => {
                const fromCode = document.getElementById("filterFrom");
                const toCode = document.getElementById("filterTo");
                const fromDisplay = document.getElementById("filterFromDisplay");
                const toDisplay = document.getElementById("filterToDisplay");

                [fromCode.value, toCode.value] = [toCode.value, fromCode.value];
                [fromDisplay.value, toDisplay.value] = [toDisplay.value, fromDisplay.value];
            });
        }

        const dateButton = document.getElementById("filterDateDisplay");
        const dateInput = document.getElementById("filterDate");
        const dateText = document.getElementById("filterDateText");
        const monthLabel = document.getElementById("adminMonthLabel");
        const calendarGrid = document.getElementById("adminCalendarGrid");
        const prevMonthBtn = document.getElementById("adminPrevMonth");
        const nextMonthBtn = document.getElementById("adminNextMonth");

        const MONTHS = [
            "January", "February", "March", "April", "May", "June",
            "July", "August", "September", "October", "November", "December"
        ];

        let adminCalendarYear = new Date().getFullYear();
        let adminCalendarMonth = new Date().getMonth();
        let adminSelectedDate = null;

        if (dateButton && adminDateDropdown) {
            dateButton.addEventListener("click", event => {
                event.stopPropagation();

                const isHidden = adminDateDropdown.classList.contains("hidden");
                adminDateDropdown.classList.toggle("hidden");

                if (isHidden) {
                    positionAdminCalendar();
                    renderAdminCalendar();
                }
            });

            document.addEventListener("click", event => {
                if (!dateButton.contains(event.target) && !adminDateDropdown.contains(event.target)) {
                    adminDateDropdown.classList.add("hidden");
                }
            });

            window.addEventListener("scroll", () => {
                if (!adminDateDropdown.classList.contains("hidden")) {
                    positionAdminCalendar();
                }
            }, true);

            window.addEventListener("resize", () => {
                if (!adminDateDropdown.classList.contains("hidden")) {
                    positionAdminCalendar();
                }
            });
        }

        if (prevMonthBtn) {
            prevMonthBtn.addEventListener("click", () => {
                adminCalendarMonth--;

                if (adminCalendarMonth < 0) {
                    adminCalendarMonth = 11;
                    adminCalendarYear--;
                }

                renderAdminCalendar();
            });
        }

        if (nextMonthBtn) {
            nextMonthBtn.addEventListener("click", () => {
                adminCalendarMonth++;

                if (adminCalendarMonth > 11) {
                    adminCalendarMonth = 0;
                    adminCalendarYear++;
                }

                renderAdminCalendar();
            });
        }

        function positionAdminCalendar() {
            const rect = dateButton.getBoundingClientRect();
            const width = 320;
            const height = 360;

            let left = rect.left;
            let top = rect.bottom + 8;

            if (left + width > window.innerWidth - 8) {
                left = window.innerWidth - width - 8;
            }

            if (left < 8) {
                left = 8;
            }

            if (top + height > window.innerHeight - 8) {
                top = rect.top - height - 8;
            }

            if (top < 8) {
                top = 8;
            }

            adminDateDropdown.style.left = left + "px";
            adminDateDropdown.style.top = top + "px";
        }

        function renderAdminCalendar() {
            if (!monthLabel || !calendarGrid) return;

            monthLabel.textContent = `${MONTHS[adminCalendarMonth]} ${adminCalendarYear}`;
            calendarGrid.innerHTML = "";

            const today = new Date();
            const firstDay = new Date(adminCalendarYear, adminCalendarMonth, 1).getDay();
            const offset = firstDay === 0 ? 6 : firstDay - 1;
            const daysInMonth = new Date(adminCalendarYear, adminCalendarMonth + 1, 0).getDate();

            for (let i = 0; i < offset; i++) {
                calendarGrid.appendChild(document.createElement("div"));
            }

            for (let day = 1; day <= daysInMonth; day++) {
                const cell = document.createElement("div");
                cell.className = "admin-cal-day";
                cell.textContent = day;

                const isToday =
                    adminCalendarYear === today.getFullYear() &&
                    adminCalendarMonth === today.getMonth() &&
                    day === today.getDate();

                const isSelected =
                    adminSelectedDate &&
                    adminSelectedDate.year === adminCalendarYear &&
                    adminSelectedDate.month === adminCalendarMonth &&
                    adminSelectedDate.day === day;

                if (isToday) {
                    cell.classList.add("admin-today");
                }

                if (isSelected) {
                    cell.classList.add("admin-selected");
                }

                cell.addEventListener("click", () => {
                    selectAdminDate(adminCalendarYear, adminCalendarMonth, day);
                });

                calendarGrid.appendChild(cell);
            }
        }

        function selectAdminDate(year, month, day) {
            const value = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;

            adminSelectedDate = { year, month, day };
            dateInput.value = value;

            dateText.textContent = `${day} ${MONTHS[month]} ${year}`;
            dateText.classList.remove("text-gray-400");
            dateText.classList.add("text-gray-800");

            renderAdminCalendar();

            setTimeout(() => {
                adminDateDropdown.classList.add("hidden");
            }, 150);
        }

        window.resetAdminEnhancedFilters = function () {
            const fromDisplay = document.getElementById("filterFromDisplay");
            const toDisplay = document.getElementById("filterToDisplay");

            if (fromDisplay) fromDisplay.value = "";
            if (toDisplay) toDisplay.value = "";

            adminSelectedDate = null;

            if (dateText) {
                dateText.textContent = "Any date";
                dateText.classList.add("text-gray-400");
                dateText.classList.remove("text-gray-800");
            }

            airportConfigs.forEach(closeAirportDropdown);

            if (adminDateDropdown) {
                adminDateDropdown.classList.add("hidden");
            }

            renderAdminCalendar();
        };

        renderAdminCalendar();
    })();

    document.addEventListener("DOMContentLoaded", async function () {
        await refreshAllDashboardData();
        await loadReservations(false);
        setActiveNav("nav-dashboard");
    });
</script>
{% endblock %}
```
