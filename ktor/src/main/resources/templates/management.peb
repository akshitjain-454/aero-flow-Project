                    <td class="px-6 py-4">
                        <div class="font-bold text-gray-900">${escapeHtml(item.firstname)} ${escapeHtml(item.lastname)}</div>
                        <div class="text-xs text-gray-400">User #${escapeHtml(item.userId)}</div>
                    </td>
                    <td class="px-6 py-4">${escapeHtml(item.email)}</td>
                    <td class="px-6 py-4 font-bold">${escapeHtml(item.flightCode)}</td>
                    <td class="px-6 py-4">${escapeHtml(item.aircraftType)}</td>
                    <td class="px-6 py-4">${escapeHtml(item.departureAirportNameCode)}</td>
                    <td class="px-6 py-4">${escapeHtml(item.arrivalAirportNameCode)}</td>
                    <td class="px-6 py-4 whitespace-nowrap">${formatDateTime(item.departureTime)}</td>
                    <td class="px-6 py-4">${statusBadge(item.bookingStatus)}</td>
                    <td class="px-6 py-4 whitespace-nowrap">${formatDateTime(item.createdAt)}</td>
                    <td class="px-6 py-4">${formatMoney(item.amountPaid)}</td>
                </tr>
            `);

            setSummary(`Reservations shown: ${results.length}`);
            renderTable(
