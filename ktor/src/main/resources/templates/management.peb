                    <td class="px-6 py-4 font-bold text-gray-900">${escapeHtml(item.flightCode)}</td>
                    <td class="px-6 py-4">${escapeHtml(item.aircraftType)}</td>
                    <td class="px-6 py-4">${escapeHtml(item.departureAirportNameCode)}</td>
                    <td class="px-6 py-4">${escapeHtml(item.arrivalAirportNameCode)}</td>
                    <td class="px-6 py-4 whitespace-nowrap">${formatDateTime(item.departureTime)}</td>
